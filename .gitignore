# ---- macOS ----
.DS_Store

# ---- Build output (regenerated by Ant/NetBeans) ----
build/
dist/
*.class

# ---- NetBeans (keep project.properties + project.xml; drop local/generated) ----
**/nbproject/private/
**/nbproject/build-impl.xml
**/nbproject/genfiles.properties

# ---- IntelliJ IDEA (local IDE settings) ----
.idea/
*.iml

# Note: the dependency jars (weka.jar, weka-src.jar, Classifier4J-0.6.jar) are
# intentionally kept in the repo — there is no build tool to fetch them, and each
# is well under GitHub's 100 MB file limit.
